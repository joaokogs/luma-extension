{
  "manifest_version": 3,
  "name": "Luma - New tab with widgets",
  "version": "1.1.0",
  "description": "Nova aba personalizável com boards, widgets, clima, calendário, notas e links — dashboard visual para organizar seu dia.",
  "author": "Luma Extension",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "tabs",
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "*://www.google.com/",
    "*://suggestqueries.google.com/*",
    "*://api.open-meteo.com/*",
    "*://geocoding-api.open-meteo.com/*",
    "*://api.bigdatacloud.net/*",
    "*://api.bing.com/*",
    "*://duckduckgo.com/*"
  ],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    },
    "default_title": "Salvar aba atual"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "luma-dashboard@luma-extension.io",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "content_security_policy": {
    "extension_pages": "default-src 'self'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' https:;"
  }
}
